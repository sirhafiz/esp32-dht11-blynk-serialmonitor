#define BLYNK_TEMPLATE_ID   "TEMPLATE_ID"   // Ganti ID kau
#define BLYNK_TEMPLATE_NAME "TEMPLATE_NAME"
#define BLYNK_AUTH_TOKEN    "AUTH_TOKEN"  // Token Blynk kau

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <DHT.h>

#define DHTPIN 4
#define DHTTYPE DHT11

char ssid[] = "HafizTM 2.4GHz";  //nama wifi kau
char pass[] = "h@f1z5335";        //pssword wifi kau

DHT dht(DHTPIN, DHTTYPE);         //pin dan jenis sensor

void setup() {
  Serial.begin(115200);
  dht.begin();                                   //mulakan sensor                      
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);     //mulakan kredential ke blynk
}

void loop() {
  Blynk.run();       //sync aktiviti ke blynk cloud

  float suhu = dht.readTemperature();
  float kelembapan = dht.readHumidity();

  if (!isnan(suhu) && !isnan(kelembapan)) { //cek suhu dan kelembapan samada ada nilai atau tidak
    //papar bacaan di serial monitor
    Serial.print("Suhu: "); 
    Serial.print(suhu); 
    Serial.print(" °C | ");
    Serial.print("Kelembapan: "); 
    Serial.print(kelembapan); 
    Serial.println(" %");

    //papar bacaan di gauge blynk
    Blynk.virtualWrite(V0, suhu);
    Blynk.virtualWrite(V1, kelembapan);
  }else{
    Serial.print("Gagal baca sensor"); //Gagal baca sensor
  }

  delay(2000); //tunggu 2 saat buat bacaan
}
